{% extends "base.html" %}
{% set current_user = nombre %}
{% set active = "renta_fija" %}
{% block title %}Renta Fija — FinTrack CO{% endblock %}
{% block content %}
<div class="page">
  <div class="topbar">
    <div><div class="page-title">Renta Fija</div><div class="page-sub">CDT · TES · Bonos · Cuentas remuneradas · Fiducias</div></div>
    <div class="top-actions">
      <button class="btn btn-primary btn-sm" onclick="openModal('modal-add')"><i class="ti ti-plus"></i> Nueva inversión</button>
    </div>
  </div>

  <div class="alert alert-info">ℹ️ <div><b>Periodos disponibles:</b> <b>Diario</b> → Nu, Lulo, Nequi cajita (rendimiento cada día) · <b>Mensual</b> → CDT mensual, Fondo SiRenta · <b>Vencimiento</b> → CDT acumulado</div></div>

  <div class="kpi-grid g3">
    <div class="kpi"><div class="kpi-label">Total RF activo</div><div class="kpi-val" id="rf-tot">$0</div></div>
    <div class="kpi"><div class="kpi-label">Rend. diario total</div><div class="kpi-val up" id="rf-dia">$0</div><div class="kpi-sub">Todas las inversiones activas</div></div>
    <div class="kpi"><div class="kpi-label">Rend. anual proyectado</div><div class="kpi-val up" id="rf-año">$0</div></div>
  </div>

  <div class="card">
    <div class="card-header"><div class="card-title">Mis inversiones de renta fija</div></div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Producto</th><th>Canal</th><th>Monto</th><th>Tasa E.A.</th><th>Comisión</th><th>Tasa neta</th><th>Período pago</th><th style="background:#f0fdf4">Rend. diario</th><th>Rend. período</th><th>Rend. anual</th><th>Acumulado</th><th>Inicio</th><th>Vence</th><th>Estado</th><th>Acciones</th></tr></thead>
        <tbody id="tabla-rf"><tr><td colspan="15"><div class="empty"><div class="empty-icon">🏦</div>Sin inversiones registradas</div></td></tr></tbody>
      </table>
    </div>
  </div>
</div>

<!-- MODAL AGREGAR / EDITAR -->
<div class="modal-overlay" id="modal-add" onclick="if(event.target===this)closeModal('modal-add')">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="modal-title">Nueva inversión de renta fija</div>
      <button class="btn-icon btn-sm" onclick="closeModal('modal-add')"><i class="ti ti-x"></i></button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="edit-id"/>
      <div class="form-grid g2f">
        <div class="form-group"><label>Tipo de producto</label>
          <select id="f-tipo">
            <option>Cuenta remunerada Nu Colombia</option>
            <option>Cuenta remunerada Lulo Bank</option>
            <option>Cajita Nequi / Daviplata</option>
            <option>Cajita Ualá</option>
            <option>CDT Bancolombia</option>
            <option>CDT Davivienda</option>
            <option>CDT Nu Colombia</option>
            <option>CDT BBVA</option>
            <option>TES Renta Fija</option>
            <option>TES UVR</option>
            <option>Bono Corporativo</option>
            <option>FIC Mercado Monetario</option>
            <option>Fiducia mercado monetario</option>
            <option>Fondo Inmobiliario (SiRenta)</option>
            <option>Otro CDT / Título</option>
          </select>
        </div>
        <div class="form-group"><label>Canal / Plataforma</label>
          <select id="f-canal">
            <option>Nu Colombia</option><option>Lulo Bank</option><option>Nequi</option>
            <option>Daviplata Inversiones</option><option>Ualá</option>
            <option>App Bancolombia</option><option>App Davivienda</option><option>Tyba (Credicorp)</option>
            <option>MejorCDT</option><option>Valores Bancolombia</option><option>Trii</option>
            <option>Acciones y Valores</option><option>Otro</option>
          </select>
        </div>
        <div class="form-group"><label>Monto invertido (COP $)</label><input type="number" id="f-monto" placeholder="1100000"/></div>
        <div class="form-group"><label>Tasa E.A. bruta (%)</label><input type="number" id="f-tasa" step="0.01" placeholder="12.4"/></div>
        <div class="form-group"><label>Comisión administración E.A. (%)</label><input type="number" id="f-com" step="0.01" placeholder="1.0" value="0"/></div>
        <div class="form-group"><label>Período de pago de rendimientos</label>
          <select id="f-periodo" onchange="updatePeriodHint()">
            <option value="diario">Diario (Nu, Lulo, Nequi cajita)</option>
            <option value="mensual" selected>Mensual (CDT mensual, SiRenta)</option>
            <option value="trimestral">Trimestral</option>
            <option value="semestral">Semestral (TES)</option>
            <option value="anual">Anual</option>
            <option value="vencimiento">Al vencimiento (CDT acumulado)</option>
          </select>
        </div>
        <div class="form-group"><label>Fecha de inicio</label><input type="date" id="f-ini"/></div>
        <div class="form-group"><label>Fecha de vencimiento</label><input type="date" id="f-vence"/></div>
        <div class="form-group"><label>Estado</label>
          <select id="f-estado"><option value="activo">Activo</option><option value="vencido">Vencido / Cobrado</option><option value="pendiente">Pendiente apertura</option></select>
        </div>
        <div class="form-group full"><label>Notas</label><input type="text" id="f-notas" placeholder="Renovación automática, condiciones, observaciones…"/></div>
      </div>
      <!-- Preview rendimientos -->
      <div id="preview-rend" style="display:none;margin-top:16px;background:var(--bg);border-radius:var(--r);padding:14px">
        <div style="font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px">Vista previa de rendimientos</div>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;text-align:center">
          <div><div style="font-size:10px;color:var(--muted)">Diario</div><div class="mono up" id="pr-dia" style="font-size:14px;font-weight:600"></div></div>
          <div><div style="font-size:10px;color:var(--muted)">Mensual</div><div class="mono up" id="pr-mes" style="font-size:14px;font-weight:600"></div></div>
          <div><div style="font-size:10px;color:var(--muted)">Anual</div><div class="mono up" id="pr-año" style="font-size:14px;font-weight:600"></div></div>
          <div><div style="font-size:10px;color:var(--muted)">Tasa neta</div><div class="mono" id="pr-neta" style="font-size:14px;font-weight:600;color:var(--blue)"></div></div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="closeModal('modal-add')">Cancelar</button>
      <button class="btn btn-primary" onclick="guardar()"><i class="ti ti-device-floppy"></i> Guardar</button>
    </div>
  </div>
</div>
{% endblock %}

{% block extra_scripts %}
<script>
// Preview de rendimientos en tiempo real
['f-monto','f-tasa','f-com','f-periodo'].forEach(id => {
  document.getElementById(id).addEventListener('input', calcPreview);
  document.getElementById(id).addEventListener('change', calcPreview);
});

function calcPreview(){
  const monto  = parseFloat(document.getElementById('f-monto').value)||0;
  const tasa   = parseFloat(document.getElementById('f-tasa').value)||0;
  const com    = parseFloat(document.getElementById('f-com').value)||0;
  const neta   = Math.max(0, tasa-com);
  const ea     = neta/100;
  if(!monto||!ea){ document.getElementById('preview-rend').style.display='none'; return; }

  const rDia = monto*(Math.pow(1+ea,1/365)-1);
  const rMes = monto*(Math.pow(1+ea,1/12)-1);
  const rAño = monto*ea;

  document.getElementById('pr-dia').textContent = '+'+COP(rDia);
  document.getElementById('pr-mes').textContent = '+'+COP(rMes);
  document.getElementById('pr-año').textContent = '+'+COP(rAño);
  document.getElementById('pr-neta').textContent = Pct(neta);
  document.getElementById('preview-rend').style.display='block';
}

function updatePeriodHint(){ calcPreview(); }

async function cargar(){
  const rows = await apiGet('/api/renta_fija');
  const tbody = document.getElementById('tabla-rf');
  if(!rows.length){
    tbody.innerHTML='<tr><td colspan="15"><div class="empty"><div class="empty-icon">🏦</div>Sin inversiones. Agrega tu primera inversión de renta fija.</div></td></tr>';
    document.getElementById('rf-tot').textContent='$0';
    document.getElementById('rf-dia').textContent='$0';
    document.getElementById('rf-año').textContent='$0';
    return;
  }

  let totM=0, totD=0, totA=0;
  const PCLS = {diario:'period-diario',mensual:'period-mensual',trimestral:'period-trimestral',semestral:'period-semestral',anual:'period-anual',vencimiento:'period-vencimiento'};

  tbody.innerHTML = rows.map(r => {
    totM += r.monto||0;
    totD += r.rend_diario||0;
    totA += r.rend_anual||0;
    const dv = r.dias_para_vencer;
    const vHtml = r.vence
      ? `<span class="tag ${dv<0?'tag-red':dv<=30?'tag-amber':'tag-green'}">${dv<0?'Vencido':r.vence}</span>`
      : '—';
    return `<tr>
      <td><b>${r.tipo}</b>${r.notas?'<br><span style="font-size:10px;color:var(--muted)">'+r.notas+'</span>':''}</td>
      <td style="color:var(--muted)">${r.canal}</td>
      <td class="mono">${COP(r.monto)}</td>
      <td class="mono up">${Pct(r.tasa_ea)}</td>
      <td class="mono dn">${Pct(r.com_ea)}</td>
      <td class="mono" style="color:var(--blue)">${Pct(r.tasa_neta)}</td>
      <td><span class="period-badge ${PCLS[r.periodo]||''}">${r.periodo}</span></td>
      <td class="t-right"><span class="rend-daily">+${COP(r.rend_diario)}</span></td>
      <td class="mono t-right up">+${COP(r.rend_periodo)}</td>
      <td class="mono t-right" style="color:var(--muted)">+${COP(r.rend_anual)}</td>
      <td class="mono t-right" style="color:var(--purple)">+${COP(r.rend_acumulado)}</td>
      <td style="color:var(--muted)">${r.ini||'—'}</td>
      <td>${vHtml}</td>
      <td><span class="tag ${r.estado==='activo'?'tag-green':r.estado==='vencido'?'tag-red':'tag-amber'}">${r.estado}</span></td>
      <td>
        <div style="display:flex;gap:4px">
          <button class="btn btn-edit btn-xs" onclick="editar(${r.id})" title="Editar"><i class="ti ti-pencil"></i></button>
          <button class="btn btn-danger btn-xs" onclick="eliminar(${r.id})" title="Eliminar"><i class="ti ti-trash"></i></button>
        </div>
      </td>
    </tr>`;
  }).join('');

  document.getElementById('rf-tot').textContent = COP(totM);
  document.getElementById('rf-dia').textContent = '+'+COP(totD);
  document.getElementById('rf-año').textContent = '+'+COP(totA);
}

function resetForm(){
  ['f-tipo','f-canal','f-monto','f-tasa','f-com','f-periodo','f-ini','f-vence','f-estado','f-notas'].forEach(id=>{
    const el=document.getElementById(id);
    if(el.tagName==='SELECT') el.selectedIndex=0;
    else el.value='';
  });
  document.getElementById('edit-id').value='';
  document.getElementById('modal-title').textContent='Nueva inversión de renta fija';
  document.getElementById('f-ini').value = new Date().toISOString().split('T')[0];
  document.getElementById('preview-rend').style.display='none';
}

async function editar(id){
  const r = await apiGet(`/api/renta_fija/${id}`);
  document.getElementById('edit-id').value       = id;
  document.getElementById('f-tipo').value        = r.tipo||'';
  document.getElementById('f-canal').value       = r.canal||'';
  document.getElementById('f-monto').value       = r.monto||'';
  document.getElementById('f-tasa').value        = r.tasa_ea||'';
  document.getElementById('f-com').value         = r.com_ea||0;
  document.getElementById('f-periodo').value     = r.periodo||'mensual';
  document.getElementById('f-ini').value         = r.ini||'';
  document.getElementById('f-vence').value       = r.vence||'';
  document.getElementById('f-estado').value      = r.estado||'activo';
  document.getElementById('f-notas').value       = r.notas||'';
  document.getElementById('modal-title').textContent = 'Editar inversión';
  calcPreview();
  openModal('modal-add');
}

async function guardar(){
  const id = document.getElementById('edit-id').value;
  const data = {
    tipo:    document.getElementById('f-tipo').value,
    canal:   document.getElementById('f-canal').value,
    monto:   parseFloat(document.getElementById('f-monto').value)||0,
    tasa_ea: parseFloat(document.getElementById('f-tasa').value)||0,
    com_ea:  parseFloat(document.getElementById('f-com').value)||0,
    periodo: document.getElementById('f-periodo').value,
    ini:     document.getElementById('f-ini').value,
    vence:   document.getElementById('f-vence').value,
    estado:  document.getElementById('f-estado').value,
    notas:   document.getElementById('f-notas').value,
  };
  if(!data.monto){ toast('Ingresa el monto',false); return; }
  const r = id
    ? await apiPut(`/api/renta_fija/${id}`, data)
    : await apiPost('/api/renta_fija', data);
  if(r.ok||r.id){ toast(id?'Inversión actualizada ✅':'Inversión guardada ✅'); closeModal('modal-add'); resetForm(); cargar(); }
  else toast('Error al guardar',false);
}

async function eliminar(id){
  if(!confirm('¿Eliminar esta inversión?')) return;
  await apiDelete(`/api/renta_fija/${id}`);
  toast('Eliminado'); cargar();
}

document.getElementById('modal-add').addEventListener('click', e => {
  if(e.target.id==='modal-add') resetForm();
});

resetForm();
cargar();
</script>
{% endblock %}

{% extends "base.html" %}
{% set current_user = nombre %}
{% set active = "rendimientos" %}
{% block title %}Rendimientos — FinTrack CO{% endblock %}
{% block content %}
<div class="page">
  <div class="topbar">
    <div>
      <div class="page-title">Rendimientos por período</div>
      <div class="page-sub">Diario · Mensual · Anual · Acumulado real desde inicio</div>
    </div>
    <div class="top-actions">
      <button class="btn btn-sm" onclick="cargar()"><i class="ti ti-refresh"></i> Actualizar</button>
    </div>
  </div>

  <!-- KPIs rendimiento -->
  <div class="kpi-grid g4" id="kpi-rend-grid">
    <div class="kpi"><div class="kpi-label">Rend. hoy (diario total)</div><div class="kpi-val up" id="kr-dia">$0</div><div class="kpi-sub">Todas las inversiones activas</div></div>
    <div class="kpi"><div class="kpi-label">Rend. mensual proyectado</div><div class="kpi-val up" id="kr-mes">$0</div><div class="kpi-sub">A tasa constante</div></div>
    <div class="kpi"><div class="kpi-label">Rend. anual proyectado</div><div class="kpi-val up" id="kr-año">$0</div><div class="kpi-sub">Interés compuesto</div></div>
    <div class="kpi"><div class="kpi-label">Rend. acumulado real</div><div class="kpi-val up" id="kr-acum">$0</div><div class="kpi-sub">Desde fecha de inicio</div></div>
  </div>

  <div class="alert alert-info">
    ℹ️ <div><b>Cuentas remuneradas (Nu, Lulo, Nequi, Cajitas):</b> el rendimiento se calcula <b>diariamente</b> por capitalización compuesta. Fondo SiRenta y fiducias se calculan según el período declarado. Los valores son estimados — confirma con el extracto de cada entidad.</div>
  </div>

  <!-- Tabla detallada -->
  <div class="card">
    <div class="card-header">
      <div><div class="card-title">Detalle por inversión</div><div class="card-sub">Ordenado por rendimiento diario</div></div>
    </div>
    <div class="table-wrap">
      <table class="rend-table">
        <thead>
          <tr>
            <th>Inversión</th>
            <th>Canal</th>
            <th>Período pago</th>
            <th class="t-right">Monto</th>
            <th class="t-right">Tasa E.A.</th>
            <th class="t-right">Tasa neta</th>
            <th class="t-right" style="background:#f0fdf4">Rend. diario</th>
            <th class="t-right">Rend. mensual</th>
            <th class="t-right">Rend. trimestral</th>
            <th class="t-right">Rend. anual</th>
            <th class="t-right">Acumulado real</th>
            <th class="t-right">Días activo</th>
            <th>Vence</th>
          </tr>
        </thead>
        <tbody id="tabla-rend">
          <tr><td colspan="13" class="empty"><div class="empty-icon">📊</div>Cargando…</td></tr>
        </tbody>
        <tfoot id="tfoot-rend" style="display:none">
          <tr style="background:var(--bg);font-weight:700;border-top:1px solid var(--border-s)">
            <td colspan="3"><b>TOTAL</b></td>
            <td class="mono t-right" id="tot-monto"></td>
            <td colspan="2"></td>
            <td class="mono t-right" id="tot-dia" style="color:var(--green)"></td>
            <td class="mono t-right" id="tot-mes"></td>
            <td class="mono t-right" id="tot-tri"></td>
            <td class="mono t-right" id="tot-año"></td>
            <td class="mono t-right" id="tot-acum"></td>
            <td colspan="2"></td>
          </tr>
        </tfoot>
      </table>
    </div>
    <div class="card-footer">
      💡 Los rendimientos diarios de cuentas remuneradas se calculan con fórmula de capitalización compuesta: <b>R_diario = Monto × ((1 + E.A.)^(1/365) − 1)</b>
    </div>
  </div>

  <!-- Guía de períodos -->
  <div class="card">
    <div class="card-header"><div class="card-title">Guía de períodos de pago en Colombia</div></div>
    <div class="card-body">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px">
        <div style="background:var(--bg);border-radius:var(--r);padding:14px">
          <div style="margin-bottom:6px"><span class="period-badge period-diario">Diario</span></div>
          <div style="font-size:13px;font-weight:600;margin-bottom:4px">Cuentas remuneradas</div>
          <div style="font-size:12px;color:var(--muted)">Nu Colombia, Lulo Bank, Nequi (cajita), Daviplata, Ualá — el rendimiento se abona cada día.</div>
        </div>
        <div style="background:var(--bg);border-radius:var(--r);padding:14px">
          <div style="margin-bottom:6px"><span class="period-badge period-mensual">Mensual</span></div>
          <div style="font-size:13px;font-weight:600;margin-bottom:4px">CDT mensual / Fiducia mensual</div>
          <div style="font-size:12px;color:var(--muted)">CDT con pago mensual de intereses. Fondo SiRenta (canon mensual). Algunos encargos fiduciarios.</div>
        </div>
        <div style="background:var(--bg);border-radius:var(--r);padding:14px">
          <div style="margin-bottom:6px"><span class="period-badge period-trimestral">Trimestral</span></div>
          <div style="font-size:13px;font-weight:600;margin-bottom:4px">CDT trimestral</div>
          <div style="font-size:12px;color:var(--muted)">Algunos CDT Bancolombia, Davivienda con pago trimestral de intereses.</div>
        </div>
        <div style="background:var(--bg);border-radius:var(--r);padding:14px">
          <div style="margin-bottom:6px"><span class="period-badge period-semestral">Semestral</span></div>
          <div style="font-size:13px;font-weight:600;margin-bottom:4px">CDT semestral / TES</div>
          <div style="font-size:12px;color:var(--muted)">TES pagan cupón semestral. CDT con pago cada 6 meses.</div>
        </div>
        <div style="background:var(--bg);border-radius:var(--r);padding:14px">
          <div style="margin-bottom:6px"><span class="period-badge period-anual">Anual</span></div>
          <div style="font-size:13px;font-weight:600;margin-bottom:4px">CDT anual / Bonos</div>
          <div style="font-size:12px;color:var(--muted)">Bonos corporativos con cupón anual. CDT con pago al año.</div>
        </div>
        <div style="background:var(--bg);border-radius:var(--r);padding:14px">
          <div style="margin-bottom:6px"><span class="period-badge period-vencimiento">Al vencimiento</span></div>
          <div style="font-size:13px;font-weight:600;margin-bottom:4px">CDT acumulado</div>
          <div style="font-size:12px;color:var(--muted)">Sin pago intermedio. Capital + intereses al vencer. Típico en CDTs corto plazo (30–180 días).</div>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block extra_scripts %}
<script>
const PERIOD_COLORS = {
  diario:'period-diario', mensual:'period-mensual', trimestral:'period-trimestral',
  semestral:'period-semestral', anual:'period-anual', vencimiento:'period-vencimiento'
};

async function cargar(){
  const rows = await apiGet('/api/rendimientos');
  const tbody = document.getElementById('tabla-rend');
  const tfoot = document.getElementById('tfoot-rend');

  if(!rows.length){
    tbody.innerHTML = '<tr><td colspan="13"><div class="empty"><div class="empty-icon">📊</div><div class="empty-text">Sin inversiones activas. Registra renta fija o activos inmobiliarios para ver los rendimientos aquí.</div></div></td></tr>';
    return;
  }

  // Ordenar por rend. diario DESC
  rows.sort((a,b) => b.rend_diario - a.rend_diario);

  let totMonto=0, totDia=0, totMes=0, totTri=0, totAño=0, totAcum=0;

  tbody.innerHTML = rows.map(r => {
    totMonto += r.monto||0;
    totDia   += r.rend_diario||0;
    totMes   += r.rend_mensual||0;
    totTri   += r.rend_trimestral||0;
    totAño   += r.rend_anual||0;
    totAcum  += r.rend_acumulado||0;

    const pCls = PERIOD_COLORS[r.periodo] || 'period-anual';
    const diasV = r.vence ? Math.ceil((new Date(r.vence)-new Date())/(1000*60*60*24)) : null;
    const venceHtml = r.vence
      ? `<span class="tag ${diasV<0?'tag-red':diasV<=30?'tag-amber':'tag-green'}">${diasV<0?'Vencido':diasV+'d'}</span>`
      : '—';

    return `<tr>
      <td><b>${r.nombre}</b><br><span style="font-size:10px;color:var(--muted)">${r.cat}</span></td>
      <td style="color:var(--muted)">${r.canal||'—'}</td>
      <td><span class="period-badge ${pCls}">${r.periodo}</span></td>
      <td class="mono t-right">${COP(r.monto)}</td>
      <td class="mono t-right">${Pct(r.tasa_ea)}</td>
      <td class="mono t-right" style="color:var(--blue)">${Pct(r.tasa_neta)}</td>
      <td class="t-right"><span class="rend-daily">+${COP(r.rend_diario)}</span></td>
      <td class="mono t-right up">+${COP(r.rend_mensual)}</td>
      <td class="mono t-right" style="color:var(--muted)">+${COP(r.rend_trimestral)}</td>
      <td class="mono t-right" style="color:var(--muted)">+${COP(r.rend_anual)}</td>
      <td class="mono t-right" style="color:var(--purple)">+${COP(r.rend_acumulado)}</td>
      <td class="mono t-right" style="color:var(--muted)">${r.dias_activo}</td>
      <td>${venceHtml}</td>
    </tr>`;
  }).join('');

  // Totales
  document.getElementById('tot-monto').textContent = COP(totMonto);
  document.getElementById('tot-dia').textContent   = '+'+COP(totDia);
  document.getElementById('tot-mes').textContent   = '+'+COP(totMes);
  document.getElementById('tot-tri').textContent   = '+'+COP(totTri);
  document.getElementById('tot-año').textContent   = '+'+COP(totAño);
  document.getElementById('tot-acum').textContent  = '+'+COP(totAcum);
  tfoot.style.display = '';

  // KPIs
  document.getElementById('kr-dia').textContent  = '+'+COP(totDia);
  document.getElementById('kr-mes').textContent  = '+'+COP(totMes);
  document.getElementById('kr-año').textContent  = '+'+COP(totAño);
  document.getElementById('kr-acum').textContent = '+'+COP(totAcum);
}

cargar();
</script>
{% endblock %}

