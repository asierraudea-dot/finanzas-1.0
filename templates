{% block extra_scripts %}
<script>
let TRM = 4200;
let RESUMEN = null;

document.getElementById('fecha-hoy').textContent = new Date().toLocaleDateString('es-CO',{weekday:'long',year:'numeric',month:'long',day:'numeric'});

async function loadDashboard(){
  // 1. Cargar mercado
  try{
    const m = await apiGet('/api/market');
    TRM = m.usd_cop || 4200;
    document.getElementById('mk-usd').textContent = TRM.toLocaleString('es-CO');
    document.getElementById('mk-usd-s').textContent = 'Actualizado hoy';
    if(m.gold_usd) document.getElementById('mk-oro').textContent = '$'+Math.round(m.gold_usd).toLocaleString('en-US');
    if(m.tasa_br)  document.getElementById('mk-br').textContent  = m.tasa_br.toFixed(2)+'%';
    if(m.ipc)      document.getElementById('mk-ipc').textContent = m.ipc.toFixed(1)+'%';
  }catch(e){}

  // 2. Resumen
  try{
    const r = await apiGet(`/api/resumen?trm=${TRM}`);
    RESUMEN = r;
    renderResumen(r);
  }catch(e){ console.error(e); }
}

function renderResumen(r){
  // Flujo
  document.getElementById('f-ing').textContent  = COP(r.ingresos);
  document.getElementById('f-gas').textContent  = COP(r.gastos);
  document.getElementById('f-aho').textContent  = COP(r.ahorro);
  document.getElementById('f-port').textContent = COP(r.portafolio);
  if(r.ingresos>0){
    document.getElementById('f-gas-p').textContent = (r.gastos/r.ingresos*100).toFixed(1)+'% del ingreso';
    document.getElementById('f-aho-p').textContent = (r.ahorro_mensual/r.ingresos*100).toFixed(1)+'% del ingreso';
  }

  // Alerta flujo
  const fa = document.getElementById('flujo-alert');
  if(r.ingresos>0){
    const pG = r.gastos/r.ingresos*100;
    if(pG>80)      fa.innerHTML=`<div class="alert alert-danger">🔴 <div><b>Gastos críticos (${pG.toFixed(1)}%)</b>Reduce gastos variables urgentemente.</div></div>`;
    else if(pG>60) fa.innerHTML=`<div class="alert alert-warn">⚠️ <div><b>Gastos elevados (${pG.toFixed(1)}%)</b>Sigue la regla 50/30/20.</div></div>`;
    else           fa.innerHTML=`<div class="alert alert-ok">✅ <div><b>Gastos saludables (${pG.toFixed(1)}%)</b>Tu flujo financiero está equilibrado.</div></div>`;
  }

  // KPIs
  const rend = r.rendimientos || {};
  document.getElementById('kpi-neto').textContent   = COP(r.neto);
  document.getElementById('kpi-neto-tag').textContent = r.neto>=0 ? 'Activos > Pasivos ✅' : '⚠️ Pasivos > Activos';
  document.getElementById('kpi-neto-tag').className  = 'kpi-delta '+(r.neto>=0?'up':'dn');
  document.getElementById('kpi-port').textContent   = COP(r.portafolio);
  document.getElementById('kpi-rend-d').textContent = COP(rend.total_diario||0);
  document.getElementById('kpi-rend-m').textContent = COP(rend.total_mensual||0);
  document.getElementById('kpi-rend-a').textContent = COP(rend.total_anual||0);
  document.getElementById('kpi-rend-ac').textContent= COP(rend.rf_acumulado||0);
  document.getElementById('kpi-deu').textContent    = COP(r.deudas);
  document.getElementById('kpi-deu-c').textContent  = COP(r.deudas_cuota||0);
  document.getElementById('kpi-deu-r').textContent  = `Ratio: ${r.portafolio>0?(r.deudas/r.portafolio*100).toFixed(1):0}%`;

  // Alertas panel
  const ap = document.getElementById('alertas-panel');
  if(r.alertas && r.alertas.length>0){
    ap.innerHTML = r.alertas.map(a=>`
      <div class="alert ${a.tipo==='critical'?'alert-danger':a.tipo==='warning'?'alert-warn':'alert-info'}">
        <span>${a.tipo==='critical'?'🔴':a.tipo==='warning'?'⚠️':'ℹ️'}</span>
        <div>${a.msg}</div>
      </div>`).join('');
    const bell = document.getElementById('bell-btn');
    const crits = r.alertas.filter(a=>a.tipo==='critical'||a.tipo==='warning').length;
    if(crits>0) bell.innerHTML = `<i class="ti ti-bell-ringing" style="color:var(--red)"></i>`;
  }
}

function openAlerts(){
  if(!RESUMEN) return;
  const body = document.getElementById('modal-alertas-body');
  const alertas = RESUMEN.alertas || [];
  if(!alertas.length){
    body.innerHTML = '<div class="empty"><div class="empty-icon">✅</div><div class="empty-text">Sin alertas activas</div></div>';
  } else {
    body.innerHTML = alertas.map(a=>`
      <div style="background:var(--bg);border-radius:9px;padding:12px 14px;margin-bottom:8px;border-left:3px solid ${a.tipo==='critical'?'var(--red)':a.tipo==='warning'?'var(--amber)':'var(--blue)'}">
        <div style="font-size:12.5px;font-weight:600;margin-bottom:3px">${a.tipo==='critical'?'🔴 Crítico':a.tipo==='warning'?'⚠️ Aviso':'ℹ️ Info'}</div>
        <div style="font-size:12px;color:var(--muted)">${a.msg}</div>
      </div>`).join('');
  }
  openModal('modal-alertas');
}

loadDashboard();
</script>
{% endblock %}

