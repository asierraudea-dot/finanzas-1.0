<title>{% block title %}FinTrack CO{% endblock %}</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:14px;-webkit-text-size-adjust:100%}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",system-ui,sans-serif;background:#f4f4f2;color:#0b0b0b;min-height:100vh}
:root{
  --bg:#f4f4f2;--surf:#fff;--border:rgba(0,0,0,.09);--border-s:rgba(0,0,0,.15);
  --text:#0b0b0b;--muted:#6b6b68;--hint:#a0a09d;
  --green:#0f7a52;--green-bg:#e8f5ee;
  --red:#c0392b;--red-bg:#fdecea;
  --blue:#185fa5;--blue-bg:#e6f1fb;
  --amber:#854f0b;--amber-bg:#faeeda;
  --purple:#4a3aa7;--purple-bg:#eeedfe;
  --r:10px;--r2:14px;
  --shadow:0 1px 4px rgba(0,0,0,.08);
  --sidebar-w:220px;
}

/* ── LAYOUT ── */
.app{display:flex;min-height:100vh}
.sidebar{width:var(--sidebar-w);flex-shrink:0;background:var(--surf);border-right:.5px solid var(--border-s);display:flex;flex-direction:column;position:fixed;top:0;left:0;height:100vh;z-index:200;overflow-y:auto;transition:transform .25s}
.main{margin-left:var(--sidebar-w);flex:1;min-height:100vh}
